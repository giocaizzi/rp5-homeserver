# Copy this file to terraform.tfvars and fill in your values

# ============================================================================
# Cloudflare Configuration
# ============================================================================

# Your Cloudflare API token with appropriate permissions
cloudflare_api_token = "your_cloudflare_api_token_here"

# Your Cloudflare account ID (found in the right sidebar of your Cloudflare dashboard)
cloudflare_account_id = "your_account_id_here"

# Domain name (should match your Cloudflare zone)
zone_name = "example.com"

# Zone ID of the domain
zone_id = "your_zone_id_here"

# Base64 encoded tunnel secret (generate with: openssl rand -base64 32)
tunnel_secret = "your_base64_tunnel_secret_here"

# List of allowed email addresses for n8n access
n8n_users = [
  "user1@example.com",
  "user2@example.com"
]

# List of allowed email addresses for Portainer
portainer_users = [
  "user1@example.com",
  "user2@example.com"
]

# List of allowed email addresses for Backrest
backrest_users = [
  "user1@example.com",
  "user2@example.com"
]

# List of allowed email addresses for Firefly III
firefly_users = [
  "user1@example.com",
  "user2@example.com"
]

# List of allowed email addresses for Grafana
grafana_users = [
  "user1@example.com",
  "user2@example.com"
]

# List of allowed email addresses for Greenhouse
greenhouse_users = [
  "user1@example.com",
  "user2@example.com"
]

# ----------------------------------------------------------------------------
# Claude.ai MCP connector tokens (app-level bearer, injected by Cloudflare).
# Use the SAME values as the corresponding Docker Swarm secrets.
# ----------------------------------------------------------------------------

# Greenhouse MCP token (= Swarm secret greenhouse_mcp_token)
greenhouse_mcp_token = "your_greenhouse_mcp_token_here"

# Firefly III Personal Access Token (= Swarm secret firefly_access_token)
firefly_mcp_token = "your_firefly_personal_access_token_here"

# n8n MCP Server Trigger bearer token
n8n_mcp_token = "your_n8n_mcp_token_here"

# ============================================================================
# GCP Configuration
# ============================================================================

# GCP project ID (from Google Cloud Console)
gcp_project_id = "your-gcp-project-id"

# GCP region (default: europe-west1)
gcp_region = "europe-west1"

# Globally unique bucket name for backups
gcp_backup_bucket_name = "your-unique-backup-bucket-name"

# Backup retention in days for GCS lifecycle deletion (0 = rely on Backrest retention)
backup_retention_days = 0