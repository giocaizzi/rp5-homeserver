# Secrets / credentials (per-service secrets/.gitignore handles the rest)
*.env
*.pem
*.key
*.crt

# OpenClaw runtime config (contains gateway tokens and auth profiles)
**/openclaw.json

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local agent-tooling shim (Portainer's git unpacker rejects symlinks).
# Recreate locally with:
#   ln -s AGENTS.md CLAUDE.md
/CLAUDE.md
/services/observability/grafana/provisioning/dashboards/CLAUDE.md

# Sub-agent worktrees (created by the harness; do not track).
.claude/worktrees/
